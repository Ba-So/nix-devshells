{
  "mcpServers": {
    "codanna": {
      "type": "stdio",
      "command": "codanna",
      "args": ["serve", "--watch", "--watch-interval", "5"]
    },
    "serena": {
      "type": "stdio",
      "command": "serena",
      "args": ["start-mcp-server", "--transport", "stdio", "--project", "."],
      "env": {}
    },
    "claude-task-master": {
      "type": "stdio",
      "command": "task-master-mcp",
      "args": [],
      "env": {
        "TASKMASTER_DIR": ".taskmaster",
        "TASK_MASTER_TOOLS": "get_tasks,set_task_status,update_task,parse_prd,add_task,add_tag,list_tags,add_dependency,remove_dependency"
      }
    },
    "cargo": {
      "args": [],
      "command": "cargo-mcp",
      "type": "stdio"
    },
    "grafana": {
      "args": [],
      "command": "mcp-grafana",
      "type": "stdio"
    }
  }
}
